GITHUB_TOKEN = (
    os.getenv("GITHUB_TOKEN")
    or os.getenv("GITHUB_PERSONAL_ACCESS_TOKEN")
    or os.getenv("GH_TOKEN")
)
BASE_URL = "https://api.github.com"

IGNORE_EXTS = {
    ".png", ".jpg", ".jpeg", ".gif", ".svg", ".ico", ".webp",
    ".woff", ".woff2", ".ttf", ".eot", ".otf",
    ".mp4", ".mp3", ".wav", ".ogg", ".webm", ".mov",
    ".pdf", ".zip", ".tar", ".gz", ".bz2", ".xz", ".7z", ".rar",
    ".exe", ".dll", ".so", ".dylib",
    ".pyc", ".pyo", ".class",
}
IGNORE_DIRS = {".git", "node_modules", "__pycache__", ".venv", "venv", ".tox"}

MAX_FILE_LINES = 500
MAX_LOG_LINES = 500


# ---------------------------------------------------------------------------
# API helpers
# ---------------------------------------------------------------------------
def _check_token():
    if not GITHUB_TOKEN:
        click.echo("GITHUB_TOKEN (or GITHUB_PERSONAL_ACCESS_TOKEN, GH_TOKEN) not set", err=True)
        sys.exit(1)


def _headers(accept="application/vnd.github.v3+json"):
    return {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": accept,
        "User-Agent": "gh-ai",
    }


def _request(path, raw=False, method="GET", json=None, timeout=30, retry=True):
    """Single API request helper. Returns decoded response (JSON or text). Exits on error."""
    _check_token()
    url = f"{BASE_URL}{path}"
    hdrs = _headers("application/vnd.github.v3.raw" if raw else "application/vnd.github.v3+json")
    try:
        if method == "GET":
            resp = requests.get(url, headers=hdrs, timeout=timeout, allow_redirects=not raw)
        elif method == "POST":
            resp = requests.post(url, headers=hdrs, json=json, timeout=timeout)
        else:
            resp = requests.request(method, url, headers=hdrs, json=json, timeout=timeout)
    except requests.RequestException as e:
        if retry and method == "GET":
            time.sleep(1)
            return _request(path, raw=raw, method=method, json=json, timeout=timeout, retry=False)
        click.echo(f"Request failed: {e}", err=True)
        sys.exit(2)

    if resp.status_code == 401:
        click.echo("Bad credentials. Check GITHUB_TOKEN", err=True)
        sys.exit(3)
    elif resp.status_code == 403:
        if "rate limit" in (resp.text or "").lower():
            reset_ts = resp.headers.get("X-RateLimit-Reset", "unknown")
            click.echo(f"Rate limited. Resets at {reset_ts}", err=True)
        else:
            click.echo(f"Forbidden (403): {resp.text[:200]}", err=True)
        sys.exit(4)
    elif resp.status_code == 404:
        click.echo(f"Not found: {path}", err=True)
        sys.exit(5)
    elif resp.status_code >= 400:
        click.echo(f"HTTP {resp.status_code}: {resp.text[:300]}", err=True)
        sys.exit(6)

    if raw:
        return resp.text
    return resp.json()


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def _login(user):
    """Safely extract login from a user object (may be null for ghost accounts)."""
    if user is None:
        return "ghost"
    return user.get("login", "unknown")


# ---------------------------------------------------------------------------
# Formatters
# ---------------------------------------------------------------------------
def _count_reactions(issue_data):
    rxns = issue_data.get("reactions", {})
    if not rxns:
        return ""
    parts = []
    for emoji in ("+1", "-1", "laugh", "hooray", "confused", "heart", "rocket", "eyes"):
        count = rxns.get(emoji, 0)
        if count:
            parts.append(f"{emoji}:{count}")
    return ", ".join(parts) if parts else ""


def _format_issue(issue, comments):
    labels = [lbl.get("name", "") for lbl in issue.get("labels", []) if lbl]
    rxns = _count_reactions(issue)
    out = {
        "title": issue.get("title", ""),
        "state": issue.get("state", ""),
        "author": _login(issue.get("user")),
        "body": issue.get("body", ""),
    }
    if labels:
        out["labels"] = ", ".join(labels)
    if issue.get("state_reason"):
        out["state_reason"] = issue["state_reason"]
    if rxns:
        out["reactions"] = rxns
    out["comments"] = [
        {"user": _login(c.get("user")), "body": c.get("body", "")}
        for c in (comments or [])
    ]
    return yaml.dump(out, allow_unicode=True, sort_keys=False, width=120)


def _format_log_errors(log_text):
    lines = log_text.splitlines()
    patterns = [
        r"\berror\b", r"\bfail(?:ed|ure)?\b", r"\bexception\b",
        r"\btraceback\b", r"\bfatal\b",
    ]
    compiled = [re.compile(p, re.IGNORECASE) for p in patterns]

    error_lines = set()
    for i, line in enumerate(lines):
        for pat in compiled:
            if pat.search(line):
                error_lines.add(i)
                break

    if not error_lines:
        return "(no errors found in log)"

    context_ranges = []
    for idx in sorted(error_lines):
        start = max(0, idx - 10)
        end = min(len(lines), idx + 11)
        context_ranges.append((start, end))

    merged = []
    for start, end in context_ranges:
        if merged and start <= merged[-1][1]:
            merged[-1] = (merged[-1][0], max(merged[-1][1], end))
        else:
            merged.append((start, end))

    out = []
    total = 0
    for start, end in merged:
        if total >= MAX_LOG_LINES:
            out.append(f"... (truncated at {MAX_LOG_LINES} lines)")
            break
        if out:
            out.append("---")
        block_end = min(end, start + (MAX_LOG_LINES - total))
        for i in range(start, block_end):
            out.append(f"{i + 1}: {lines[i]}")
            total += 1

    return "\n".join(out)


def _format_search_repos(results):
    out = []
    items = results.get("items", [])[:5]
    if not items:
        return "(no results)"
    for i, item in enumerate(items, 1):
        stars = item.get("stargazers_count", 0)
        lang = item.get("language") or "?"
        desc = (item.get("description") or "").strip()
        out.append(f"{i}. {item['full_name']} ★ {stars} | {lang}")
        if desc:
            out.append(f"   {desc}")
    return "\n".join(out)


def _format_search_issues(results):
    out = []
    items = results.get("items", [])[:5]
    if not items:
        return "(no results)"
    for i, item in enumerate(items, 1):
        repo = item.get("repository_url", "").rsplit("/", 2)[-2:]
        repo_name = "/".join(repo) if len(repo) == 2 else "?"
        title = item.get("title", "")
        state = item.get("state", "")
        num = item.get("number", "?")
        out.append(f"{i}. [{repo_name}#{num}] {title} ({state})")
    return "\n".join(out)


def _format_pr(pr, reviews):
    labels = [lbl.get("name", "") for lbl in pr.get("labels", []) if lbl]
    head = pr.get("head", {})
    base = pr.get("base", {})
    out = {
        "title": pr.get("title", ""),
        "state": pr.get("state", ""),
        "author": _login(pr.get("user")),
        "body": pr.get("body", ""),
        "branch": f"{head.get('ref', '?')} → {base.get('ref', '?')}",
        "mergeable": pr.get("mergeable_state", "unknown"),
        "draft": pr.get("draft", False),
    }
    if labels:
        out["labels"] = ", ".join(labels)
    if pr.get("additions") is not None:
        out["diff"] = f"+{pr['additions']} -{pr['deletions']} ({pr.get('changed_files', 0)} files)"
    if pr.get("state_reason"):
        out["state_reason"] = pr["state_reason"]
    if reviews:
        out["reviews"] = [
            {"user": _login(r.get("user")), "state": r.get("state", ""),
             "body": (r.get("body") or "")[:200]}
            for r in reviews
        ]
    return yaml.dump(out, allow_unicode=True, sort_keys=False, width=120)


def _format_checks(check_runs):
    if not check_runs:
        return "(no checks)"
    lines = []
    for c in check_runs:
        name = c.get("name", "?")
        status = c.get("status", "?")
        conclusion = c.get("conclusion") or "—"
        icon = "✓" if conclusion == "success" else "✗" if conclusion in ("failure", "timed_out", "cancelled") else "○"
        lines.append(f"{icon} {name}: {conclusion} ({status})")
    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Patch engines
# ---------------------------------------------------------------------------
def _apply_diff(filepath, diff_text):
    hunk_pattern = re.compile(r"^@@ -(\d+),?(\d*) \+(\d+),?(\d*) @@\s*(.*)$", re.MULTILINE)

    if os.path.exists(filepath):
        with open(filepath, "r") as f:
            original = f.read()
        orig_lines = original.splitlines(keepends=True)
        shutil.copy2(filepath, filepath + ".bak")
    else:
        orig_lines = []

    hunks = []
    current_hunk = None
    for line in diff_text.splitlines(keepends=True):
        if line.startswith("@@"):
            if current_hunk:
                hunks.append(current_hunk)
            m = hunk_pattern.match(line)
            if m:
                current_hunk = {
                    "old_start": int(m.group(1)),
                    "old_count": int(m.group(2)) if m.group(2) else 1,
                    "new_start": int(m.group(3)),
                    "new_count": int(m.group(4)) if m.group(4) else 1,
                    "lines": [],
                }
        elif current_hunk is not None:
            current_hunk["lines"].append(line)

    if current_hunk:
        hunks.append(current_hunk)

    if not hunks:
        return _apply_search_replace(filepath, diff_text)

    for hunk in reversed(hunks):
        old_start = hunk["old_start"] - 1
        old_count = hunk["old_count"]
        new_lines = []

        for line in hunk["lines"]:
            if line.startswith(" "):
                new_lines.append(line[1:])
            elif line.startswith("+"):
                new_lines.append(line[1:])

        if old_start >= 0 and old_count > 0 and orig_lines:
            line_idx = old_start
            for line in hunk["lines"]:
                if line.startswith(" ") or line.startswith("-"):
                    expected = line[1:].rstrip("\n")
                    actual = orig_lines[line_idx].rstrip("\n") if line_idx < len(orig_lines) else ""
                    if expected != actual:
                        click.echo(
                            f"Context mismatch at line {line_idx + 1}: "
                            f"expected '{expected[:60]}' got '{actual[:60]}'",
                            err=True,
                        )
                        sys.exit(1)
                    line_idx += 1

        end = old_start + old_count if old_start >= 0 else 0
        if old_start < 0:
            orig_lines = new_lines
        else:
            orig_lines[old_start:end] = new_lines

    with open(filepath, "w") as f:
        f.write("".join(orig_lines))

    return "✓ Patch applied"


def _apply_search_replace(filepath, text):
    pattern = re.compile(
        r"<<<<<<< ORIGINAL\n(.*?)=======\n(.*?)>>>>>>> REPLACEMENT",
        re.DOTALL,
    )

    if os.path.exists(filepath):
        with open(filepath, "r") as f:
            content = f.read()
    else:
        content = ""

    matches = pattern.findall(text)
    if not matches:
        return "No search/replace blocks found"

    for original, replacement in matches:
        original = original.rstrip("\n")
        replacement = replacement.lstrip("\n").rstrip("\n")

        count = content.count(original)
        if count == 0:
            click.echo(f"Search block not found in file: {original[:80]}...", err=True)
            sys.exit(1)
        elif count > 1:
            click.echo(f"Search block is not unique (found {count} occurrences)", err=True)
            sys.exit(1)

        content = content.replace(original, replacement, 1)

    if os.path.exists(filepath):
        shutil.copy2(filepath, filepath + ".bak")
    with open(filepath, "w") as f:
        f.write(content)

    return "✓ Patch applied"


# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------
def _git(*args):
    cmd = ["git"] + list(args)
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            click.echo(f"Git failed: git {' '.join(args)}\n{result.stderr.strip()}", err=True)
            sys.exit(7)
        return result.stdout.strip()
    except subprocess.TimeoutExpired:
        click.echo(f"Git timed out: git {' '.join(args)}", err=True)
        sys.exit(8)
    except FileNotFoundError:
        click.echo("git not found on PATH", err=True)
        sys.exit(9)


