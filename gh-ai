    else:
        data = _request(f"/search/issues?q={encoded}&per_page=5&sort=created&order=desc")
        click.echo(_format_search_issues(data))


# ---- get-action-errors --------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("run_id")
def get_action_errors(repo, run_id):
    """Fetch GitHub Actions logs and extract only error blocks with context."""
    _request(f"/repos/{repo}/actions/runs/{run_id}")

    url = f"{BASE_URL}/repos/{repo}/actions/runs/{run_id}/logs"
    resp = requests.get(url, headers=_headers(), allow_redirects=True, timeout=60)
    if resp.status_code != 200:
        click.echo(f"Failed to fetch logs: HTTP {resp.status_code}", err=True)
        sys.exit(6)

    ansi_escape = re.compile(r"\x1b\[[0-9;]*[a-zA-Z]")

    try:
        with zipfile.ZipFile(io.BytesIO(resp.content)) as zf:
            all_logs = []
            for name in sorted(zf.namelist()):
                with zf.open(name) as f:
                    text = f.read().decode("utf-8", errors="replace")
                    text = ansi_escape.sub("", text)
                    all_logs.append(f"# {name}\n{text}")
            log_text = "\n".join(all_logs)
    except (zipfile.BadZipFile, OSError):
        log_text = ansi_escape.sub("", resp.text)

    click.echo(_format_log_errors(log_text))


# ---- apply-patch --------------------------------------------------------
@cli.command()
@click.argument("file_path")
def apply_patch(file_path):
    """Apply a patch from stdin (unified diff or search/replace block)."""
    if sys.stdin.isatty():
        click.echo("No patch provided on stdin. Pipe a diff or search/replace block.", err=True)
        sys.exit(1)

    patch_text = sys.stdin.read()

    if not patch_text.strip():
        click.echo("Empty patch input.", err=True)
        sys.exit(1)

    if patch_text.startswith("<<<<<<< ORIGINAL") or "<<<<<<< ORIGINAL" in patch_text:
        result = _apply_search_replace(file_path, patch_text)
    elif re.search(r"^--- .+\n\+\+\+ .+", patch_text, re.MULTILINE) or "@@" in patch_text:
        result = _apply_diff(file_path, patch_text)
    else:
        if "<<<<<<<" in patch_text:
            result = _apply_search_replace(file_path, patch_text)
        else:
            result = _apply_diff(file_path, patch_text)

    click.echo(result)


# ---- create-pr ----------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("base_branch")
@click.argument("new_branch")
@click.option("--title", required=True, help="PR title (also used as commit message)")
@click.option("--body", required=True, help="PR description")
@click.option("--draft", is_flag=True, default=False, help="Create as draft PR")
@click.option("--dry-run", is_flag=True, default=False, help="Show what would happen, stop before push")
def create_pr(repo, base_branch, new_branch, title, body, draft, dry_run):
    """Macro: commit local changes, push, and create a PR."""
    _check_token()

    status = _git("status", "--porcelain")
    if not status.strip():
        click.echo("No changes to commit (working tree clean)", err=True)
        sys.exit(1)

    click.echo(f"1. Creating branch: {new_branch}")
    _git("checkout", "-b", new_branch)

    click.echo("2. Staging all changes")
    _git("add", "-A")

    click.echo(f"3. Committing: {title}")
    _git("commit", "-m", title)

    if dry_run:
        click.echo(f"\nDry run — stopping before push. Branch: {new_branch}")
        click.echo("Changes committed locally but NOT pushed.")
        return

    click.echo(f"4. Pushing to origin/{new_branch}")
    _git("push", "origin", new_branch)

    click.echo("5. Creating pull request...")
    payload = {"title": title, "body": body, "head": new_branch, "base": base_branch, "draft": draft}
    resp = requests.post(
        f"{BASE_URL}/repos/{repo}/pulls",
        headers=_headers(),
        json=payload,
        timeout=30,
    )
    if resp.status_code == 201:
        pr = resp.json()
        click.echo(f"✓ PR #{pr['number']} created: {pr['html_url']}")
    else:
        click.echo(f"Failed to create PR: HTTP {resp.status_code}\n{resp.text[:300]}", err=True)
        sys.exit(6)


