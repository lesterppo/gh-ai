def _git(*args):
    cmd = ["git"] + list(args)
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            err = result.stderr.strip()
            if "Author identity unknown" in err:
                click.echo("Git identity not set. Run:\n  git config user.email \"you@example.com\"\n  git config user.name \"Your Name\"", err=True)
            else:
                click.echo(f"Git failed: git {' '.join(args)}\n{err}", err=True)
            sys.exit(7)
        return result.stdout.strip()
    except subprocess.TimeoutExpired:
        click.echo(f"Git timed out: git {' '.join(args)}", err=True)
        sys.exit(8)
    except FileNotFoundError:
        click.echo("git not found on PATH", err=True)
        sys.exit(9)


