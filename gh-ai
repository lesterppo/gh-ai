@cli.command()
@click.argument("file_path")
def apply_patch(file_path):
    """Apply a patch from stdin (unified diff or search/replace block)."""
    if sys.stdin.isatty():
        click.echo("No patch provided on stdin. Pipe a diff or search/replace block.", err=True)
        sys.exit(1)

    patch_text = sys.stdin.read()

    if not patch_text.strip():
        click.echo("Empty patch input.", err=True)
        sys.exit(1)

    if patch_text.startswith("<<<<<<< ORIGINAL") or "<<<<<<< ORIGINAL" in patch_text:
        result = _apply_search_replace(file_path, patch_text)
    elif re.search(r"^--- .+\n\+\+\+ .+", patch_text, re.MULTILINE) or "@@" in patch_text:
        result = _apply_diff(file_path, patch_text)
    else:
        if "<<<<<<<" in patch_text:
            result = _apply_search_replace(file_path, patch_text)
        else:
            result = _apply_diff(file_path, patch_text)

    click.echo(result)


# ---- repo-init ----------------------------------------------------------
@cli.command()
@click.argument("name")
@click.option("--description", default="", help="Repository description")
@click.option("--private", "private_", is_flag=True, default=False, help="Create private repo")
@click.option("--org", default=None, help="Create under an organization instead of user")
@click.option("--dry-run", is_flag=True, default=False, help="Show what would happen, don't create repo")
def repo_init(name, description, private_, org, dry_run):
    """Create a new GitHub repo and push local content as the initial commit."""
    _check_token()

    status = subprocess.run(["git", "status", "--porcelain"], capture_output=True, text=True).stdout.strip()
    has_changes = bool(status)
    is_repo = os.path.isdir(".git")

    if not is_repo and not has_changes:
        if not os.listdir("."):
            click.echo("No files to push. Create some files first.", err=True)
            sys.exit(1)

    if org:
        owner = org
        repo_path = f"{org}/{name}"
        create_url = f"/orgs/{org}/repos"
    else:
        user_data = _request("/user")
        owner = user_data["login"]
        repo_path = f"{owner}/{name}"
        create_url = "/user/repos"

    payload = {"name": name, "description": description, "private": private_, "auto_init": False}

    if dry_run:
        click.echo(f"Would create {'private' if private_ else 'public'} repo: {repo_path}")
    else:
        click.echo(f"1. Creating {'private' if private_ else 'public'} repo: {repo_path}")
        resp = requests.post(
            f"{BASE_URL}{create_url}",
            headers=_headers(),
            json=payload,
            timeout=30,
        )
        if resp.status_code == 422:
            click.echo(f"Repo {repo_path} may already exist: {resp.json().get('errors', [{}])[0].get('message', 'unknown')}", err=True)
            sys.exit(6)
        elif resp.status_code != 201:
            click.echo(f"Failed to create repo: HTTP {resp.status_code}\n{resp.text[:300]}", err=True)
            sys.exit(6)
        repo_data = resp.json()
        clone_url = repo_data["clone_url"]

    if not is_repo:
        click.echo("2. Initializing git repository")
        if not dry_run:
            _git("init")
    else:
        click.echo("2. Using existing git repository")

    # Ensure git identity is set (only matters for fresh repos)
    if not dry_run:
        for key, default in [("user.email", "gh-ai@agent.local"), ("user.name", "gh-ai")]:
            val = subprocess.run(["git", "config", key], capture_output=True, text=True).stdout.strip()
            if not val:
                _git("config", key, default)

    if has_changes or not is_repo:
        click.echo("3. Staging all files")
        if not dry_run:
            _git("add", "-A")
        click.echo("4. Committing")
        if not dry_run:
            _git("commit", "-m", description or "Initial commit")
    else:
        click.echo("3-4. Using existing commits")

    if dry_run:
        click.echo(f"\nDry run — would push to {repo_path}")
        return

    click.echo("5. Setting remote and pushing to main")
    remotes = subprocess.run(["git", "remote"], capture_output=True, text=True).stdout.strip()
    if "origin" in remotes.splitlines():
        _git("remote", "set-url", "origin", clone_url)
    else:
        _git("remote", "add", "origin", clone_url)
    _git("branch", "-M", "main")
    _git("push", "-u", "origin", "main")

    click.echo(f"✓ Repo created: {repo_data['html_url']}")


# ---- create-pr ----------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("base_branch")
@click.argument("new_branch")
@click.option("--title", required=True, help="PR title (also used as commit message)")
@click.option("--body", default=None, help="PR description")
@click.option("--body-file", default=None, help="Read PR description from file")
@click.option("--draft", is_flag=True, default=False, help="Create as draft PR")
@click.option("--dry-run", is_flag=True, default=False, help="Show what would happen, stop before push")
def create_pr(repo, base_branch, new_branch, title, body, body_file, draft, dry_run):
    """Macro: commit local changes, push, and create a PR.

    Body can come from --body, --body-file, or stdin.
    """
    _check_token()

    resolved_body = _require_body(body, body_file)

    status = _git("status", "--porcelain")
    if not status.strip():
        click.echo("No changes to commit (working tree clean)", err=True)
        sys.exit(1)

    click.echo(f"1. Creating branch: {new_branch}")
    _git("checkout", "-b", new_branch)

    click.echo("2. Staging all changes")
    _git("add", "-A")

    click.echo(f"3. Committing: {title}")
    _git("commit", "-m", title)

    if dry_run:
        click.echo(f"\nDry run — stopping before push. Branch: {new_branch}")
        click.echo("Changes committed locally but NOT pushed.")
        return

    click.echo(f"4. Pushing to origin/{new_branch}")
    _git("push", "origin", new_branch)

    click.echo("5. Creating pull request...")
    payload = {"title": title, "body": resolved_body, "head": new_branch, "base": base_branch, "draft": draft}
    resp = requests.post(
        f"{BASE_URL}/repos/{repo}/pulls",
        headers=_headers(),
        json=payload,
        timeout=30,
    )
    if resp.status_code == 201:
        pr = resp.json()
        click.echo(f"✓ PR #{pr['number']} created: {pr['html_url']}")
    else:
        click.echo(f"Failed to create PR: HTTP {resp.status_code}\n{resp.text[:300]}", err=True)
        sys.exit(6)


