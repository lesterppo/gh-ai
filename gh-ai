@click.option("--max-lines", type=int, default=300, help="Maximum diff lines (default 300)")
def pr_diff(repo, pr_number, max_lines):
    """Get PR diff with line numbers. Truncated by default."""
    _check_token()

    text = requests.get(
        f"{BASE_URL}/repos/{repo}/pulls/{pr_number}",
        headers=_headers("application/vnd.github.v3.diff"),
        timeout=30,
    ).text

    if not text:
        click.echo("(empty diff)")
        return

    lines = text.splitlines()
    total = len(lines)
    if total > max_lines:
        lines = lines[:max_lines]

    for i, line in enumerate(lines, 1):
        click.echo(f"{i}: {line}")

    if total > max_lines:
        click.echo(f"... (truncated: {total - max_lines} more lines)")


