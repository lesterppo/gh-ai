@cli.command()
@click.argument("repo")
@click.option("--title", required=True, help="Issue title")
@click.option("--body", default=None, help="Issue body text")
@click.option("--body-file", default=None, help="Read body from file")
@click.option("--label", "labels", multiple=True, help="Add label (repeatable)")
def issue_create(repo, title, body, body_file, labels):
    """Create a new issue."""
    _check_token()

    resolved_body = _require_body(body, body_file)
    payload = {"title": title, "body": resolved_body}
    if labels:
        payload["labels"] = list(labels)

    data = _request(f"/repos/{repo}/issues", method="POST", json=payload)
    click.echo(f"✓ Issue #{data['number']} created: {data['html_url']}")


