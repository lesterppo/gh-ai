# ---- pr-checks ----------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("pr_number", type=int)
def pr_checks(repo, pr_number):
    """Show CI check statuses for a PR. Returns one line per check with conclusion."""
    _check_token()

    # Get head SHA from PR
    pr = requests.get(
        f"{BASE_URL}/repos/{repo}/pulls/{pr_number}",
        headers=_headers(),
        timeout=30,
    ).json()
    if "message" in pr:
        click.echo(f"Not found: {repo}#{pr_number}", err=True)
        sys.exit(5)

    head_sha = pr.get("head", {}).get("sha")
    if not head_sha:
        click.echo("No head SHA found", err=True)
        sys.exit(1)

    # Fetch check runs
    check_runs = requests.get(
        f"{BASE_URL}/repos/{repo}/commits/{head_sha}/check-runs",
        headers=_headers("application/vnd.github.v3+json"),
        timeout=30,
    ).json()

    runs = check_runs.get("check_runs", [])
    click.echo(_format_checks(runs))


