    or os.getenv("GITHUB_PERSONAL_ACCESS_TOKEN")
    or os.getenv("GH_TOKEN")
)
BASE_URL = "https://api.github.com"

IGNORE_EXTS = {
    ".png", ".jpg", ".jpeg", ".gif", ".svg", ".ico", ".webp",
    ".woff", ".woff2", ".ttf", ".eot", ".otf",
    ".mp4", ".mp3", ".wav", ".ogg", ".webm", ".mov",
