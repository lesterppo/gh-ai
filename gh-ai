# ---- rate-limit ----------------------------------------------------------
@cli.command()
def rate_limit():
    """Show current GitHub API rate limit status."""
    data = _request("/rate_limit")
    core = data.get("resources", {}).get("core", {})
    search = data.get("resources", {}).get("search", {})
    click.echo(f"core:   {core.get('remaining', '?')}/{core.get('limit', '?')} remaining, resets {time.strftime('%H:%M:%S', time.localtime(core.get('reset', 0)))}")
    click.echo(f"search: {search.get('remaining', '?')}/{search.get('limit', '?')} remaining, resets {time.strftime('%H:%M:%S', time.localtime(search.get('reset', 0)))}")


# ---- repo-tree ----------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.option("--max", "max_results", type=int, default=200, help="Maximum file paths to return")
def repo_tree(repo, max_results):
    """Fetch repository file tree, filtered for code files only."""
    data = _request(f"/repos/{repo}/git/trees/HEAD?recursive=1")
    tree = data.get("tree", [])
    if not tree:
        click.echo("(empty repository or truncated tree)")
        return

    paths = []
    for item in tree:
        path = item.get("path", "")
        if not path:
            continue
        _, ext = os.path.splitext(path)
        if ext.lower() in IGNORE_EXTS:
            continue
        parts = path.split("/")
        if any(d in IGNORE_DIRS for d in parts):
            continue
        paths.append(path)

    paths.sort()
    total = len(paths)
    paths = paths[:max_results]
    for p in paths:
        click.echo(p)
    if total > max_results:
        click.echo(f"... (truncated: {total - max_results} more files)")


# ---- file-read ----------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("path")
@click.option("--start", type=int, default=None, help="First line (1-indexed)")
@click.option("--end", type=int, default=None, help="Last line (1-indexed, inclusive)")
def file_read(repo, path, start, end):
    """Read a file with line numbers. Supports --start/--end for slicing."""
    encoded_path = urllib.parse.quote(path, safe="")
    text = _request(f"/repos/{repo}/contents/{encoded_path}", raw=True)

    lines = text.splitlines()
    line_start = start or 1
    line_end = end or len(lines)

    if line_start < 1:
        line_start = 1
    if line_end > len(lines):
        line_end = len(lines)

    sliced = lines[line_start - 1 : line_end]
    total = len(sliced)

    if total > MAX_FILE_LINES:
        sliced = sliced[:MAX_FILE_LINES]
        trunc = True
    else:
        trunc = False

    for i, line in enumerate(sliced):
        click.echo(f"{line_start + i}: {line}")

    if trunc:
        click.echo(f"... (truncated: {total - MAX_FILE_LINES} more lines)")


# ---- issue-view ---------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("issue_number", type=int)
def issue_view(repo, issue_number):
    """View issue with all comments in compact YAML.

    REPO format: owner/name
    """
    _check_token()

    base = f"{BASE_URL}/repos/{repo}/issues/{issue_number}"

    def fetch_issue():
        return requests.get(base, headers=_headers(), timeout=30).json()

    def fetch_comments():
        return requests.get(f"{base}/comments", headers=_headers(), timeout=30).json()

    with ThreadPoolExecutor(max_workers=2) as executor:
        issue_future = executor.submit(fetch_issue)
        comments_future = executor.submit(fetch_comments)
        issue = issue_future.result()
        comments = comments_future.result()

    if "message" in issue:
        click.echo(f"Not found: {repo}#{issue_number}", err=True)
        sys.exit(5)

    click.echo(_format_issue(issue, comments))


