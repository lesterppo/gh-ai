@cli.command()
@click.argument("repo")
@click.argument("pr_number", type=int)
def pr_status(repo, pr_number):
    """One-line PR status: state, mergeable, CI conclusion, URL."""
    _check_token()

    pr = requests.get(
        f"{BASE_URL}/repos/{repo}/pulls/{pr_number}",
        headers=_headers(),
        timeout=30,
    ).json()
    if "message" in pr:
        click.echo(f"Not found: {repo}#{pr_number}", err=True)
        sys.exit(5)

    state = pr.get("state", "?")
    merged = pr.get("merged", False)
    draft = "📝" if pr.get("draft") else ""
    mergeable = pr.get("mergeable_state", "?")

    # Get CI conclusion from head SHA
    head_sha = pr.get("head", {}).get("sha")
    ci = "?"
    if head_sha:
        checks = requests.get(
            f"{BASE_URL}/repos/{repo}/commits/{head_sha}/check-runs",
            headers=_headers(),
            timeout=30,
        ).json()
        conclusions = {c.get("conclusion") for c in checks.get("check_runs", []) if c.get("conclusion")}
        if not conclusions:
            ci = "no_checks"
        elif all(c == "success" for c in conclusions):
            ci = "✓"
        elif any(c in ("failure", "timed_out", "cancelled") for c in conclusions):
            ci = "✗"
        else:
            ci = "○"

    status = "merged" if merged else state
    click.echo(f"{status}{' ' + draft if draft else ''} | mergeable: {mergeable} | ci: {ci} | {pr['html_url']}")


# ---- pr-merge -----------------------------------------------------------
@cli.command()
@click.argument("repo")
@click.argument("pr_number", type=int)
@click.option("--squash", is_flag=True, default=False, help="Squash and merge")
@click.option("--rebase", is_flag=True, default=False, help="Rebase and merge")
@click.option("--delete-branch", is_flag=True, default=False, help="Delete head branch after merge")
def pr_merge(repo, pr_number, squash, rebase, delete_branch):
    """Merge a PR. Defaults to standard merge commit."""
    _check_token()

    if squash and rebase:
        click.echo("Cannot use both --squash and --rebase", err=True)
        sys.exit(1)

    method = "squash" if squash else "rebase" if rebase else "merge"
    payload = {"merge_method": method}
    if delete_branch:
        payload["delete_branch"] = True

    data = _request(
        f"/repos/{repo}/pulls/{pr_number}/merge",
        method="PUT",
        json=payload,
    )
    if data.get("merged"):
        msg = "✓ Merged"
        if delete_branch:
            msg += " (branch deleted)"
        click.echo(f"{msg}: {data.get('message', '')}")
    else:
        click.echo(f"Merge failed: {data.get('message', 'unknown')}", err=True)
        sys.exit(6)


